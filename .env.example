# =============================================================================
# STT Inference — environment template
# Copy to .env and edit. Never commit .env.
# =============================================================================

# ---- HuggingFace ----
# Required for gated models; Qwen3-ASR + Whisper-Large-v3 are public so optional
HF_TOKEN=
# Shared cache path on the host (mounted into all containers)
HF_CACHE_DIR=./hf_cache

# ---- Model selection ----
QWEN_MODEL=Qwen/Qwen3-ASR-1.7B
WHISPER_MODEL=openai/whisper-large-v3

# Pin model revisions for reproducibility (fill in after first successful pull)
QWEN_REVISION=main
WHISPER_REVISION=main

# ---- vLLM serving ----
QWEN_PORT=8000
WHISPER_PORT=8001

# Share GPU between the two models; 0.35 each leaves headroom for KV cache
QWEN_GPU_MEMORY_UTILIZATION=0.35
WHISPER_GPU_MEMORY_UTILIZATION=0.35

QWEN_MAX_NUM_SEQS=16
WHISPER_MAX_NUM_SEQS=16

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000

# Internal URLs the backend uses to reach vLLM (compose DNS names)
QWEN_URL=http://qwen:8000
WHISPER_URL=http://whisper:8001

# ---- Logging / observability ----
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | console
LOG_TRANSCRIPT_CONTENT=false # if true, DEBUG logs include transcript text (PII)

# ---- VAD ----
VAD_THRESHOLD=0.5            # 0..1, speech probability
VAD_MIN_SILENCE_MS=500       # silence before emitting a segment
VAD_MIN_SPEECH_MS=250        # ignore shorter-than-this blips
VAD_MAX_SEGMENT_MS=15000     # force-cut after this long

# ---- Session limits ----
WS_MAX_SESSION_SECONDS=1800  # 30 min hard cap per WS session
WS_MAX_AUDIO_QUEUE=200       # bounded backpressure queue

# ---- HTTP client ----
VLLM_TIMEOUT_SECONDS=60
VLLM_RETRIES=2

# ---- Security / CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- GPU ----
# To pin specific GPUs, uncomment and set (e.g. "0" or "0,1").
# Leave commented out to use ALL visible GPUs — setting CUDA_VISIBLE_DEVICES to
# an empty string actually HIDES all GPUs and breaks the vLLM containers.
#CUDA_VISIBLE_DEVICES=0
